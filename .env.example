# Скопируйте этот файл в .env и заполните значения для локального запуска.
# На Railway эти переменные задаются в разделе Variables.

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
GEMINI_API_KEY=your_google_ai_studio_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Для локального запуска вебхук не нужен — бот автоматически переключится в polling.
# WEBHOOK_URL=https://your-app.up.railway.app
# PORT=8000
